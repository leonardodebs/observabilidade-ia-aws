# Copie para .env e ajuste se necessario.
# Os scripts em src/ e o proxy usam estas variaveis (com valores padrao sensatos).

# Regiao AWS onde a infra foi criada.
AWS_DEFAULT_REGION=us-west-2

# Prefixo dos recursos (deve casar com o 'prefixo' do Terraform).
PREFIXO=lab4

# Nomes derivados (sobrescreva apenas se mudar o prefixo no Terraform).
DYNAMODB_TABLE=lab4-incidents
LOG_GROUP=/lab4/app-simulation

# Opcional: URL da Lambda Function URL (se nao definida, e lida do output do Terraform).
# API_URL=https://xxxx.lambda-url.us-west-2.on.aws

# As credenciais AWS NAO ficam aqui — use 'aws configure' ou variaveis de ambiente
# padrao (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY) fora do versionamento.
